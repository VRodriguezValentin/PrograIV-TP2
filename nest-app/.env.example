# Variables de entorno de ejemplo para el backend
# Copia este archivo a .env y reemplaza los valores con tus credenciales reales.

MONGO_URL=mongodb://<usuario>:<password>@<host>:<puerto>/<database>?ssl=true&replicaSet=<replicaSet>&authSource=admin
PORT=3000
CLOUDINARY_CLOUD_NAME=<cloud_name>
CLOUDINARY_API_KEY=<api_key>
CLOUDINARY_API_SECRET=<api_secret>
